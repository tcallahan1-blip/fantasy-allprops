# Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser. Required by scripts/seed.js
# and the pick-window cron route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only. Shared secret Vercel Cron sends as `Authorization: Bearer
# <value>` to /api/cron/pick-windows — generate with `openssl rand -hex 32`.
CRON_SECRET=your-cron-secret
